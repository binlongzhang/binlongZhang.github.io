---
export interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;

// 显示 h1 / h2 / h3 三级标题
const tocHeadings = headings.filter(h => h.depth >= 1 && h.depth <= 3);
---

{tocHeadings.length > 0 && (
	<nav class="toc expanded" aria-label="Table of Contents">
		<button class="toc-tab" aria-label="展开/收起目录">
			<svg class="toc-tab-icon" width="18" height="18" viewBox="0 0 16 16" fill="currentColor">
				<path d="M2 3.5h12v1.5H2zM2 7.25h12v1.5H2zM2 11h8v1.5H2z"/>
			</svg>
			<svg class="toc-tab-arrow" width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
				<path d="M10.5 8l-4 4V4z"/>
			</svg>
		</button>
		<div class="toc-content">
			<ul class="toc-list">
				{tocHeadings.map(heading => (
					<li class={`toc-level-${heading.depth}`}>
						<a href={`#${heading.slug}`}>{heading.text}</a>
					</li>
				))}
			</ul>
		</div>
	</nav>
)}

<style>
	.toc {
		position: fixed;
		left: 0;
		top: 0;
		height: 100vh;
		z-index: 100;
		transition: transform 0.3s ease;
	}

	/* 侧边标签页 */
	.toc-tab {
		position: absolute;
		left: 0;
		top: 50%;
		transform: translateY(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.4rem;
		background: linear-gradient(135deg, rgb(var(--accent)), rgba(var(--accent), 0.8));
		color: white;
		border: none;
		border-radius: 0 8px 8px 0;
		padding: 0.9rem 0.45rem;
		cursor: pointer;
		box-shadow: 2px 2px 8px rgba(var(--black), 0.15);
		transition: all 0.3s ease;
		z-index: 101;
	}

	.toc-tab:hover {
		padding-right: 0.65rem;
		box-shadow: 3px 3px 12px rgba(var(--black), 0.25);
	}

	/* 展开时箭头翻转指向收起方向 */
	.toc-tab-arrow {
		transition: transform 0.3s ease;
	}

	.toc.expanded .toc-tab-arrow {
		transform: rotate(180deg);
	}

	/* 主内容区 */
	.toc-content {
		position: absolute;
		left: 0;
		top: 0;
		width: 280px;
		height: 100vh;
		background: linear-gradient(to bottom,
			rgba(255, 255, 255, 0.98),
			rgba(250, 250, 252, 0.98));
		backdrop-filter: blur(10px);
		border-right: 1px solid rgba(var(--gray-light), 0.6);
		box-shadow: 4px 0 16px rgba(var(--black), 0.08);
		transform: translateX(-280px);
		transition: transform 0.3s ease;
		display: flex;
		flex-direction: column;
	}

	.toc.expanded .toc-content {
		transform: translateX(0);
	}

	.toc.expanded .toc-tab {
		left: 280px;
	}

	.toc-list {
		list-style: none;
		margin: 0;
		padding: 1.5rem;
		overflow-y: auto;
		flex: 1;
	}

	.toc-list li {
		margin: 0.4rem 0;
		line-height: 1.4;
	}

	/* h1 标题样式（最顶层，最醒目） */
	.toc-list li.toc-level-1 {
		margin-left: 0;
		margin-top: 0.6rem;
	}

	.toc-list li.toc-level-1 > a {
		font-weight: 700;
		color: rgb(var(--black));
		font-size: 1.02em;
	}

	/* h2 标题样式（缩进一级） */
	.toc-list li.toc-level-2 {
		margin-left: 1rem;
	}

	.toc-list li.toc-level-2 > a {
		font-weight: 500;
		color: rgb(var(--gray-dark));
	}

	/* h3 标题样式（缩进两级） */
	.toc-list li.toc-level-3 {
		margin-left: 2rem;
		font-size: 0.88em;
	}

	.toc-list li.toc-level-3 > a {
		color: rgb(var(--gray));
	}

	.toc-list a {
		display: block;
		text-decoration: none;
		padding: 0.4rem 0.75rem;
		border-radius: 6px;
		transition: all 0.2s ease;
		border-left: 3px solid transparent;
	}

	.toc-list a:hover {
		background: rgba(var(--accent), 0.1);
		color: rgb(var(--accent));
		border-left-color: rgba(var(--accent), 0.4);
		transform: translateX(2px);
	}

	.toc-list a.active {
		background: rgba(var(--accent), 0.15);
		color: rgb(var(--accent));
		font-weight: 600;
		border-left-color: rgb(var(--accent));
	}

	/* 屏幕小于 1400px 时隐藏目录 */
	@media (max-width: 1400px) {
		.toc {
			display: none;
		}
	}
</style>

<script>
	// 展开/收起功能
	const tocTab = document.querySelector('.toc-tab');
	const tocNav = document.querySelector('.toc');

	if (tocTab && tocNav) {
		tocTab.addEventListener('click', () => {
			tocNav.classList.toggle('expanded');
		});

		// 点击目录链接后自动收起
		document.querySelectorAll('.toc-list a').forEach(link => {
			link.addEventListener('click', () => {
				tocNav.classList.remove('expanded');
			});
		});
	}

	// 高亮当前阅读位置
	const observer = new IntersectionObserver((entries) => {
		entries.forEach((entry) => {
			const id = entry.target.getAttribute('id');
			if (entry.isIntersecting) {
				document.querySelectorAll('.toc-list a').forEach(a => a.classList.remove('active'));
				const activeLink = document.querySelector(`.toc-list a[href="#${id}"]`);
				if (activeLink) activeLink.classList.add('active');
			}
		});
	}, { rootMargin: '-100px 0px -66%' });

	// 观察所有标题
	document.querySelectorAll('.prose h1[id], .prose h2[id], .prose h3[id]').forEach((heading) => {
		observer.observe(heading);
	});
</script>
