---
import { getCollection } from 'astro:content';
import type { GetStaticPaths, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

export const getStaticPaths = (async ({ paginate }) => {
	const posts = (await getCollection('blog')).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);
	// 注意：getStaticPaths 在隔离上下文执行，pageSize 直接内联（不能引用模块级常量）
	return paginate(posts, { pageSize: 5 });
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<'blog'>> };
const { page } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 800px;
				max-width: calc(100% - 2em);
			}
			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-list li {
				padding: 1.5rem 0;
				border-bottom: 1px solid rgba(var(--gray-light), 0.9);
			}
			.post-list li:first-child {
				padding-top: 0;
			}
			.post-list a {
				display: block;
				text-decoration: none;
				transition: 0.2s ease;
			}
			.title-row {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				flex-wrap: wrap;
				gap: 0.6rem;
				margin: 0 0 0.4rem 0;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				font-size: 1.4rem;
				line-height: 1.3;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				white-space: nowrap;
			}
			.desc {
				margin: 0;
				color: rgb(var(--gray-dark));
				font-size: 0.9rem;
				line-height: 1.5;
			}
			.post-list a:hover .title {
				color: rgb(var(--accent));
			}
			.pagination {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-top: 2.5rem;
			}
			.pagination .page-info {
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.pagination a {
				padding: 0.45rem 1rem;
				border: 1px solid rgba(var(--gray-light), 0.9);
				border-radius: 8px;
				text-decoration: none;
				color: rgb(var(--accent));
				transition: 0.2s ease;
			}
			.pagination a:hover {
				background: rgba(var(--accent-rgb), 0.08);
			}
			.pagination .spacer {
				width: 1px;
			}
			@media (max-width: 720px) {
				.title {
					font-size: 1.2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul class="post-list">
					{
						page.data.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<div class="title-row">
										<h2 class="title">{post.data.title}</h2>
										<span class="date">
											<FormattedDate date={post.data.pubDate} />
										</span>
									</div>
									{post.data.description && <p class="desc">{post.data.description}</p>}
								</a>
							</li>
						))
					}
				</ul>

				{
					page.lastPage > 1 && (
						<nav class="pagination" aria-label="Pagination">
							{page.url.prev ? (
								<a href={page.url.prev} rel="prev">
									← 上一页
								</a>
							) : (
								<span class="spacer" />
							)}
							<span class="page-info">
								第 {page.currentPage} / {page.lastPage} 页
							</span>
							{page.url.next ? (
								<a href={page.url.next} rel="next">
									下一页 →
								</a>
							) : (
								<span class="spacer" />
							)}
						</nav>
					)
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
